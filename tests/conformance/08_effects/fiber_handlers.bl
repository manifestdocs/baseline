// Conformance: non-tail-resumptive effect handlers (fiber-based)
//
// These handlers do work AFTER resume(), requiring fiber-based coroutines.
// Tail-resumptive handlers (where the body is just `resume(expr)`) use
// evidence passing instead.

// Test 1: Non-tail-resumptive handler — work after resume
// Handler does addition after resuming the body.
test "work after resume" = handle {
  Console.println!("hello")
  10
} with {
  Console.println!(msg, resume) -> {
    let r = resume(())
    r + 5
  }
} == 15

// Test 2: Abort handler — no resume call
// Handler returns immediately without resuming the body.
test "abort handler no resume" = handle {
  Console.println!("hello")
  42
} with {
  Console.println!(msg) -> -1
} == -1

// Test 3: Multiple performs in one body
// Each perform yields to the handler, which resumes and adds to the result.
test "multiple performs" = handle {
  Console.println!("a")
  Console.println!("b")
  100
} with {
  Console.println!(msg, resume) -> {
    let r = resume(())
    r + 1
  }
} == 102

// Test 4: Handler transforms resume value
// The handler passes a value to the continuation via resume.
test "handler transforms resume value" = handle {
  let x = Console.println!("get value")
  x + 10
} with {
  Console.println!(msg, resume) -> {
    let r = resume(42)
    r
  }
} == 52

// Test 5: Nested handlers — tail-resumptive inside non-tail-resumptive
test "nested tail inside non-tail" = handle {
  handle {
    Console.println!("inner")
    50
  } with {
    Console.println!(msg, resume) -> resume(())
  }
} with {
  Console.println!(msg, resume) -> {
    let r = resume(())
    r + 7
  }
} == 50

// Test 6: Nested non-tail-resumptive inside non-tail-resumptive (same effect)
// Inner handler catches the first perform, outer catches the second.
// Inner handler adds 10, outer handler adds 100.
test "nested non-tail inside non-tail" = handle {
  let x = handle {
    Console.println!("inner")
    0
  } with {
    Console.println!(msg, resume) -> {
      let r = resume(())
      r + 10
    }
  }
  Console.println!("outer")
  x
} with {
  Console.println!(msg, resume) -> {
    let r = resume(())
    r + 100
  }
} == 110

// Test 7: Effect args flow through fiber
// The handler reads the argument passed to the performed effect.
test "effect args flow through fiber" = handle {
  let x = Console.println!("msg")
  x + 10
} with {
  Console.println!(msg, resume) -> {
    let r = resume(42)
    r
  }
} == 52
